<Window x:Class="MemoryLoomApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Memory Loom"
        Width="720"
        Height="320"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Border Padding="22"
            Background="#FCFCFD"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            CornerRadius="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="36"
                              Direction="270"
                              Opacity="0.2"
                              ShadowDepth="12"
                              Color="#111827" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True">
                <TextBlock DockPanel.Dock="Left"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           FontSize="22"
                           Foreground="#111827"
                           Text="Search" />
                <TextBox x:Name="SearchBox"
                         Height="46"
                         Padding="14,8"
                         VerticalContentAlignment="Center"
                         Background="#F9FAFB"
                         BorderBrush="#D1D5DB"
                         BorderThickness="1"
                         FontSize="18"
                         Foreground="#111827"
                         KeyDown="SearchBox_OnKeyDown"
                         TextChanged="SearchBox_OnTextChanged" />
            </DockPanel>

            <ListBox x:Name="ResultsList"
                     Grid.Row="2"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="0,9">
                            <StackPanel>
                                <TextBlock Text="{Binding Content}"
                                           FontSize="14"
                                           Foreground="#111827"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding Source}"
                                           FontSize="12"
                                           Foreground="#6B7280" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock x:Name="StatusText"
                       Grid.Row="3"
                       Margin="0,12,0,0"
                       FontSize="12"
                       Foreground="#6B7280"
                       Text="Press Enter to search. Press Esc to close." />
        </Grid>
    </Border>
</Window>
