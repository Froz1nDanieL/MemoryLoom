<Window x:Class="MemoryLoomApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Memory Loom"
        Width="960"
        Height="340"
        MinWidth="760"
        MinHeight="260"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5FCFD" />
        <SolidColorBrush x:Key="GlassBorderBrush" Color="#5FDFFCF2" />
        <SolidColorBrush x:Key="GlassInnerBorderBrush" Color="#38FFFFFF" />
        <FontFamily x:Key="CodexUiFont">Microsoft YaHei UI, Microsoft YaHei, PingFang SC, OpenAI Sans, Inter, Segoe UI Variable Text, Segoe UI</FontFamily>

        <DropShadowEffect x:Key="DialogShadow"
                          BlurRadius="30"
                          Direction="270"
                          Opacity="0.16"
                          ShadowDepth="10"
                          Color="#052C35" />

        <DropShadowEffect x:Key="ResultsShadow"
                          BlurRadius="26"
                          Direction="270"
                          Opacity="0.1"
                          ShadowDepth="8"
                          Color="#06363E" />

        <Style x:Key="InvisibleTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="#F2F7FAFC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="#17353A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#FFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#E9F3F6F8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#45FFFFFF" />
                                <Setter Property="Foreground" Value="#7A35555B" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Padding="12,10"
                                Background="#10FFFFFF"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="0.5"
                                CornerRadius="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#18FFFFFF" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#36DFFCF2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#22DFFCF2" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#56DFFCF2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent"
          ClipToBounds="True">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Border x:Name="DialogChrome"
                    Width="560"
                    Height="124"
                    Padding="1"
                    CornerRadius="20"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="0.6"
                    Effect="{StaticResource DialogShadow}"
                    MouseLeftButtonDown="DialogChrome_OnMouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#06272D" Offset="0" />
                        <GradientStop Color="#06272D" Offset="0.52" />
                        <GradientStop Color="#06272D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Border CornerRadius="19"
                        BorderBrush="{StaticResource GlassInnerBorderBrush}"
                        BorderThickness="0.4">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop x:Name="DialogLeftStop" Color="#06272D" Offset="0" />
                            <GradientStop x:Name="DialogMiddleStop" Color="#06272D" Offset="0.48" />
                            <GradientStop x:Name="DialogRightStop" Color="#06272D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid Margin="20,16,14,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="34" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock x:Name="SearchPlaceholder"
                                       Margin="0,1,0,0"
                                       FontFamily="{StaticResource CodexUiFont}"
                                       FontSize="15"
                                       Foreground="#BFEAF0"
                                       IsHitTestVisible="False"
                                       Text="Ask Memory Loom..." />

                            <TextBox x:Name="SearchBox"
                                     Style="{StaticResource InvisibleTextBoxStyle}"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Top"
                                     AcceptsReturn="False"
                                     CaretBrush="#F5FCFD"
                                     FontFamily="{StaticResource CodexUiFont}"
                                     FontSize="15"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     SelectionBrush="#6FDFFCF2"
                                     TextWrapping="Wrap"
                                     GotKeyboardFocus="SearchBox_OnGotKeyboardFocus"
                                     LostKeyboardFocus="SearchBox_OnLostKeyboardFocus"
                                     KeyDown="SearchBox_OnKeyDown"
                                     TextChanged="SearchBox_OnTextChanged" />
                        </Grid>

                        <Button x:Name="SearchButton"
                                Grid.Row="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource SendButtonStyle}"
                                Click="SearchButton_OnClick"
                                IsEnabled="False">
                            <TextBlock Margin="0,-2,0,0"
                                       FontFamily="Segoe UI Symbol, Segoe UI"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="&#x2191;" />
                        </Button>
                    </Grid>
                </Border>
            </Border>

            <Border x:Name="ResultsPanel"
                    Width="340"
                    MaxHeight="250"
                    Margin="16,0,0,0"
                    Padding="1"
                    CornerRadius="20"
                    BorderBrush="#40DFFCF2"
                    BorderThickness="0.5"
                    Effect="{StaticResource ResultsShadow}"
                    Opacity="0"
                    Visibility="Collapsed"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform X="30" />
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#082D35" Offset="0" />
                        <GradientStop Color="#0A4035" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Border CornerRadius="19"
                        BorderBrush="#38FFFFFF"
                        BorderThickness="0.5"
                        Background="#0A3540">
                    <ListBox x:Name="ResultsList"
                             Margin="10"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource ResultItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Content}"
                                           FontSize="12.5"
                                           FontFamily="{StaticResource CodexUiFont}"
                                           Foreground="#F2FBFC"
                                           LineHeight="18"
                                           MaxHeight="76"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Border>
        </StackPanel>
    </Grid>
</Window>
